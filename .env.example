# Neon Postgres — run db/schema.sql in your project first
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin dashboard password (required for /admin)
ADMIN_PASSWORD=choose-a-strong-password

# --- Email (no custom domain needed) — use Gmail SMTP ---
# 1. Google Account → Security → 2-Step Verification ON
# 2. App passwords → create one for "Mail" → copy 16-char password
SMTP_USER=yourclub@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=Lecathon <yourclub@gmail.com>
ADMIN_NOTIFICATION_EMAIL=yourclub@gmail.com
SEND_REGISTRATION_CONFIRMATION=true

# Optional: Resend (needs a verified domain for real participants;
# onboarding@resend.dev only emails YOUR Resend account address)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Lecathon <onboarding@resend.dev>
